---
import Base from '../layouts/Base.astro';
import Presenter from '../components/Presenter.astro';
import { sectionHref } from '../lib/content';
const base = import.meta.env.BASE_URL;
// p3's prompt list, one card at a time. The full list also lives at /s/p3.
---
<Base title="p3">
  <Presenter src={`${base}p3.json`} backHref={sectionHref(base, 'p3')} backLabel="‹ p3 (full list)" />
</Base>
