---
import Base from '../layouts/Base.astro';
import Presenter from '../components/Presenter.astro';
import { sectionHref } from '../lib/content';
const base = import.meta.env.BASE_URL;
// The 959 preliminary/auxiliary practices, one at a time. Indexed by Appendix 1;
// practices are NOT global sections (kept out of the sidebar/tree/random), but
// their read/star/hide state still syncs because section_state keys on any string.
---
<Base title="Auxiliary practice — Globway">
  <Presenter
    src={`${base}aux.json`}
    backHref={sectionHref(base, 'appendix-1-preliminary-auxiliary-practices-names-on')}
    backLabel="‹ Appendix 1 — all preliminary/auxiliary practices"
  />
</Base>
