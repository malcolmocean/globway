---
import '../styles/global.css';
import Tree from '../components/Tree.astro';
import NavBar from '../components/NavBar.astro';
import AuthBar from '../components/AuthBar.astro';
import { buildTree } from '../lib/content';
interface Props { title: string; current?: string; home?: boolean; }
const { title, current, home = false } = Astro.props;
const base = import.meta.env.BASE_URL;
const tree = buildTree();

const MANUAL = 'Global Wayfinding Meditation Manual';
const host = Astro.site?.host ?? 'globway.top';
const pageTitle = home ? `${MANUAL} [mirror at ${host}]` : `${title} ༄ ${MANUAL}`;
const ogImage = new URL(`${base}gwhf.jpg`, Astro.site ?? `https://${host}`).href;
const canonical = new URL(Astro.url.pathname, Astro.site ?? `https://${host}`).href;
const description =
  "An interactive mirror of Mark Lippmann's Manual of Global Wayfinding Meditation.";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="color-scheme" content="light dark" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="manifest" href={`${base}manifest.webmanifest`} />
    <meta name="theme-color" content="#0b0b0c" />
    <link rel="apple-touch-icon" href={`${base}icons/icon-192.png`} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="Wayfinding" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={MANUAL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1920" />
    <meta property="og:image:height" content="1080" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <button type="button" class="nav-toggle" data-nav-toggle aria-label="Table of contents">
      <span aria-hidden="true">☰</span> Contents
    </button>
    <div class="nav-backdrop" data-nav-backdrop></div>
    <div class="app">
      <aside class="sidebar">
        <a class="brand" href={base}>
          Global Wayfinding Meditation
          <small>Mark Lippmann's protocol, interactive</small>
        </a>
        <AuthBar />
        <NavBar />
        <nav aria-label="Table of contents">
          <Tree nodes={tree} current={current} showWordcount={false} />
        </nav>
        <footer class="sidebar-foot">
          A rearranged reading of the
          <a href="https://meditationbook.page" rel="noopener">canonical document</a>
          by “meditationstuff” (Mark Lippmann). This edition may lag the original.
        </footer>
      </aside>
      <main class="main">
        <slot />
      </main>
    </div>
    <script>
      import '../scripts/app.ts';
    </script>
    <script is:inline define:vars={{ base }}>
      // Register the offline service worker (generated at build time by
      // scripts/build-sw.mjs). Guarded so dev (no sw.js) is a harmless no-op.
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register(base + 'sw.js').catch(() => {});
        });
      }
    </script>
  </body>
</html>
