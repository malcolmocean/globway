---
// Sidebar quick-nav: filter pills (filter the TOC tree in place, document-wide),
// landmark jumps, and a random not-hidden section. Behaviour lives in app.ts.
import { sectionHref } from '../lib/content';
const base = import.meta.env.BASE_URL;
// Landmark jump buttons — edit freely; keys are real section anchors.
const landmarks = [
  { label: 'pre/aux', key: 'preliminary-auxiliary-practices' },
  { label: 'p3', key: 'p3' },
  { label: 'p8', key: 'p8' },
];
const filters = [
  { id: 'all', label: 'All' },
  { id: 'starred', label: '★' },
  { id: 'read', label: '✓ Read' },
  { id: 'unread', label: 'Unread' },
  { id: 'hidden', label: '⊘ Hidden' },
];
---
<div class="navbar" data-navbar>
  <div class="navbar-row" role="group" aria-label="Filter the table of contents">
    {filters.map((f) => (
      <button type="button" class="pill" data-filter={f.id} aria-pressed={f.id === 'all' ? 'true' : 'false'}>{f.label}</button>
    ))}
  </div>
  <div class="navbar-row">
    {landmarks.map((l) => (
      <a class="pill jump" href={sectionHref(base, l.key)}>{l.label}</a>
    ))}
    <button type="button" class="pill jump" data-action="random-jump" title="Jump to a random section">🎲</button>
  </div>
</div>
