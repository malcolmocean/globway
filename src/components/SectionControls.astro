---
interface Props { sectionKey: string; }
const { sectionKey } = Astro.props;
---
<div class="controls">
  <button type="button" data-action="read" data-key={sectionKey} aria-pressed="false">
    <span aria-hidden="true">✓</span> Read
  </button>
  <button type="button" data-action="star" data-key={sectionKey} aria-pressed="false">
    <span aria-hidden="true">★</span> Star
  </button>
  <button type="button" data-action="hide" data-key={sectionKey} aria-pressed="false" class="hide-btn">
    <span aria-hidden="true">⊘</span> Hide
  </button>
</div>
