# Copy to .env.local for local Supabase-backed dev. Without these, the app runs
# in localStorage-only mode (still fully usable). The anon key is PUBLIC by design
# (safe to expose in the browser) — RLS is what protects data.
PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Optional site config (defaults assume a custom domain at the root):
# PUBLIC_SITE_URL=https://your-domain.example
# PUBLIC_BASE_PATH=/        # or /globway for a github.io project page
